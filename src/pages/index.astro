---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* App Cards Grid */
			.tools-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.5rem;
				margin-top: 2rem;
			}
			.app-card {
				display: flex;
				flex-direction: column;
				text-decoration: none;
			}
			.app-card:hover {
				background: var(--surface-hover);
			}
			.app-card-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				margin-bottom: 1rem;
			}
			.app-icon {
				font-size: 2rem;
				background: var(--grid-color);
				padding: 0.5rem;
				border-radius: 8px;
				line-height: 1;
			}
			.app-tag {
				font-size: 0.75rem;
				color: var(--text-secondary);
				background: var(--grid-color);
				padding: 0.2rem 0.6rem;
				border-radius: 4px;
				border: 1px solid var(--line-color);
				letter-spacing: 1px;
			}
			.app-title {
				color: var(--text-primary);
				font-size: 1.25rem;
				font-weight: 700;
				margin: 0 0 0.5rem 0;
				font-family: 'Space Grotesk', sans-serif;
			}
			.app-desc {
				color: var(--text-secondary);
				font-size: 0.95rem;
				line-height: 1.5;
				margin: 0;
			}
		</style>
	</head>
	<body>
		<div class="layout-wrapper">
			<Header />
			<main>
				<div style="margin-bottom: 4rem;">
					<h1 style="margin-bottom: 0.1em;">{SITE_TITLE}</h1>
					<p style="font-size: 1.1rem;">
						Exploring the cosmos of code, design, and ideas. A minimalist haven for thoughts.
					</p>
				</div>

				<div class="tool-card">
					<h2>About Me</h2>
					<p>
						Hello! I'm a developer passionate about building modern, sleek, and high-performance applications. 
						This blog is where I document my journey, share technical insights, and explore the boundaries of web development.
					</p>
					<a href="/blog" class="font-mono" style="text-decoration: underline; font-weight: bold;">-> Read My Blog</a>
				</div>

				<div class="tool-card">
					<h2>Sub-Projects & Tools</h2>
					<p>Interactive utilities deployed on GitHub Pages.</p>
					
					<div class="tools-grid">
						<a href="https://zhao20060708.github.io/malody2osu/" target="_blank" class="tool-card app-card" style="margin-bottom: 0;">
							<div class="app-card-header">
								<div class="app-icon">🎵</div>
								<div class="app-tag font-mono">UTILITY</div>
							</div>
							<h3 class="app-title">malody2osu</h3>
							<p class="app-desc">Convert Malody charts to osu! format seamlessly inside your browser.</p>
						</a>
						
						<a href="https://zhao20060708.github.io/osu-downloader/" target="_blank" class="tool-card app-card" style="margin-bottom: 0;">
							<div class="app-card-header">
								<div class="app-icon">⬇️</div>
								<div class="app-tag font-mono">UTILITY</div>
							</div>
							<h3 class="app-title">osu-downloader</h3>
							<p class="app-desc">Download osu! beatmaps easily with a modern web interface.</p>
						</a>
					</div>
				</div>
			</main>
			<Footer />
		</div>
	</body>
</html>
