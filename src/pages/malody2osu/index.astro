---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import config from "@/config";
import pythonCode from "./core.py?raw";
---

<Layout title={`Malody to osu!mania | ${config.site.title}`}>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,1,0" rel="stylesheet" slot="head" />
  <script src="https://cdn.jsdelivr.net/pyodide/v0.24.1/full/pyodide.js" slot="head" is:inline></script>
  
  <Header activeNav="malody2osu" />
  
  <Main pageTitle="Malody to osu!mania" pageDesc="无需安装，完全在浏览器本地运行，支持手机与电脑">
    <div class="mt-8 bg-background border border-border p-8 rounded shadow-sm relative before:absolute before:left-[-1px] before:top-[-1px] before:bottom-[-1px] before:w-[3px] before:bg-accent">
      <div id="initStatus" class="text-center p-8 flex flex-col items-center gap-6">
          <div class="loader w-12 h-12 border-4 border-border border-t-accent rounded-full animate-spin"></div>
          <div id="initText" class="text-base font-medium text-muted-foreground">正在初始化 Python 环境 (约需几秒钟)...</div>
      </div>

      <div id="uploadContainer" class="hidden">
          <div id="uploadArea" class="border-2 border-dashed border-border rounded-lg py-12 px-6 text-center cursor-pointer transition-all bg-background hover:bg-accent/5 hover:border-accent group">
              <span class="material-symbols-rounded text-5xl text-accent mb-4">upload_file</span>
              <div class="text-lg font-medium text-foreground mb-2" id="text-upload-title">点击选择 .mcz 文件，或将文件拖拽至此处</div>
              <div class="text-sm text-muted-foreground" id="text-upload-sub">支持同时上传多个文件</div>
              <input type="file" id="fileInput" multiple class="hidden">
          </div>
          
          <div id="fileList" class="mt-6 flex flex-col gap-3 max-h-96 overflow-y-auto pr-2"></div>
      </div>
    </div>
  </Main>
  <Footer />
</Layout>

<style is:global>
  .loader {
      border-top-color: var(--color-accent) !important;
  }
  @keyframes slideIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
  }
  .file-item {
      animation: slideIn 0.3s ease-out forwards;
      @apply bg-background border border-border rounded p-4 flex items-center gap-4;
  }
  .file-icon {
      @apply text-muted-foreground text-3xl;
  }
  .file-info {
      @apply flex-grow min-w-0;
  }
  .file-name {
      @apply text-[0.95rem] font-medium whitespace-nowrap overflow-hidden text-ellipsis mb-1 text-foreground;
  }
  .file-status-text {
      @apply text-[0.85rem] text-muted-foreground;
  }
  .status-icon-container {
      @apply flex items-center justify-center w-8 h-8;
  }
  .status-icon {
      @apply text-2xl;
  }
  .status-icon.success { @apply text-green-500; }
  .status-icon.error { @apply text-red-500; }
</style>

<script type="text/python" id="pythonCode" is:inline set:html={pythonCode} />

<script is:inline>
const i18n = {
            'en': {
                back: '← Back to Workspace',
                subtitle: 'No installation required, completely runs locally in browser. Supports mobile and PC.',
                initWait: 'Initializing Python Environment (takes a few seconds)...',
                initFail: 'Environment initialization failed. Please refresh and try again.',
                uploadTitle: 'Click to select .mcz files, or drag & drop here',
                uploadSub: 'Supports multiple file upload at once',
                unsupportedFiles: (n) => `${n} unsupported files filtered. Please upload .mcz or .zip files only.`,
                waitProcess: 'Waiting to process...',
                processing: 'Converting...',
                fail: 'Conversion failed',
                success: 'Conversion successful! Download starting.',
                langToggle: '中文'
            },
            'zh': {
                back: '← 返回工作区',
                subtitle: '无需安装，完全在浏览器本地运行，支持手机与电脑',
                initWait: '正在初始化 Python 环境 (约需几秒钟)...',
                initFail: '环境初始化失败，请刷新重试',
                uploadTitle: '点击选择 .mcz 文件，或将文件拖拽至此处',
                uploadSub: '支持同时上传多个文件',
                unsupportedFiles: (n) => `有 ${n} 个文件格式不支持，已自动过滤。请仅上传 .mcz 或 .zip 文件。`,
                waitProcess: '等待处理...',
                processing: '正在转换...',
                fail: '转换失败',
                success: '转换成功！即将开始下载。',
                langToggle: 'English'
            }
        };

        let currentLang = 'zh';

        function toggleLang() {
            currentLang = currentLang === 'zh' ? 'en' : 'zh';
            updateLang();
        }

        function updateLang() {
            const texts = i18n[currentLang];
            
            
            const initTextEl = document.getElementById('initText');
            if (initTextEl) initTextEl.innerText = texts.initWait;
            document.getElementById('text-upload-title').innerText = texts.uploadTitle;
            document.getElementById('text-upload-sub').innerText = texts.uploadSub;
            
            
            document.querySelectorAll('.file-item').forEach(item => {
                const id = item.id;
                const statusTextEl = document.getElementById(`${id}-text`);
                if (statusTextEl) {
                    const status = statusTextEl.getAttribute('data-status');
                    if (status === 'waiting') {
                        statusTextEl.innerText = texts.waitProcess;
                    } else if (status === 'processing') {
                        statusTextEl.innerText = texts.processing;
                    } else if (status === 'success') {
                        statusTextEl.innerText = texts.success;
                    } else if (status === 'fail') {
                        statusTextEl.innerText = texts.fail;
                    } else if (status && status.startsWith('error:')) {
                        statusTextEl.innerText = (currentLang === 'zh' ? '错误: ' : 'Error: ') + status.substring(6);
                    }
                }
            });
            
        }

        let pyodide;
        let isProcessing = false;
        const fileQueue = [];

        async function init() {
            try {
                pyodide = await loadPyodide();
                await pyodide.runPythonAsync(document.getElementById('pythonCode').innerText);
                document.getElementById('initStatus').classList.add('hidden');
                document.getElementById('uploadContainer').classList.remove('hidden');
            } catch (err) {
                const texts = i18n[currentLang];
                document.getElementById('initStatus').innerHTML = `
                    <span class="material-symbols-rounded" style="color: var(--error); font-size: 48px;">error</span>
                    <div style="color: var(--error);">${texts.initFail}</div>
                `;
                console.error(err);
            }
        }
        init();

        const uploadArea = document.getElementById('uploadArea');
        const fileInput = document.getElementById('fileInput');
        const fileList = document.getElementById('fileList');

        uploadArea.addEventListener('click', () => fileInput.click());
        uploadArea.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadArea.classList.add('dragover');
        });
        uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('dragover'));
        uploadArea.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadArea.classList.remove('dragover');
            if (e.dataTransfer.files.length) {
                handleFilesInput(e.dataTransfer.files);
            }
        });
        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length) {
                handleFilesInput(e.target.files);
                fileInput.value = ''; 
            }
        });

        function handleFilesInput(files) {
            const validFiles = [];
            let invalidCount = 0;
            
            for (let file of files) {
                if (file.name.toLowerCase().endsWith('.mcz') || file.name.toLowerCase().endsWith('.zip')) {
                    validFiles.push(file);
                } else {
                    invalidCount++;
                }
            }
            
            if (invalidCount > 0) {
                alert(i18n[currentLang].unsupportedFiles(invalidCount));
            }
            
            if (validFiles.length > 0) {
                enqueueFiles(validFiles);
            }
        }

        function enqueueFiles(files) {
            for (let file of files) {
                const id = 'file-' + Math.random().toString(36).substr(2, 9);
                const texts = i18n[currentLang];
                
                // Build DOM elements instead of innerHTML to prevent XSS via file.name
                const item = document.createElement('div');
                item.className = 'file-item';
                item.id = id;

                const icon = document.createElement('span');
                icon.className = 'material-symbols-rounded file-icon';
                icon.textContent = 'draft';

                const info = document.createElement('div');
                info.className = 'file-info';

                const nameDiv = document.createElement('div');
                nameDiv.className = 'file-name';
                nameDiv.title = file.name;
                nameDiv.textContent = file.name;

                const statusDiv = document.createElement('div');
                statusDiv.className = 'file-status-text';
                statusDiv.id = id + '-text';
                statusDiv.setAttribute('data-status', 'waiting');
                statusDiv.textContent = texts.waitProcess;

                info.appendChild(nameDiv);
                info.appendChild(statusDiv);

                const statusContainer = document.createElement('div');
                statusContainer.className = 'status-icon-container';
                statusContainer.id = id + '-icon';

                const scheduleIcon = document.createElement('span');
                scheduleIcon.className = 'material-symbols-rounded status-icon';
                scheduleIcon.style.opacity = '0.5';
                scheduleIcon.textContent = 'schedule';
                statusContainer.appendChild(scheduleIcon);

                item.appendChild(icon);
                item.appendChild(info);
                item.appendChild(statusContainer);

                fileList.prepend(item);
                
                fileQueue.push({ file, id });
            }
            processQueue();
        }

        async function processQueue() {
            if (isProcessing || fileQueue.length === 0) return;
            isProcessing = true;
            
            const item = fileQueue.shift();
            await handleFile(item.file, item.id);
            
            isProcessing = false;
            processQueue();
        }

        async function handleFile(file, id) {
            const texts = i18n[currentLang];
            const statusText = document.getElementById(`${id}-text`);
            const statusIcon = document.getElementById(`${id}-icon`);
            
            statusText.setAttribute('data-status', 'processing');
            statusText.innerText = texts.processing;
            statusText.style.color = 'var(--accent)';
            statusIcon.innerHTML = `<div class="loader"></div>`;

            await new Promise(resolve => setTimeout(resolve, 50));

            try {
                const arrayBuffer = await file.arrayBuffer();
                const uint8Array = new Uint8Array(arrayBuffer);
                
                const processFunc = pyodide.globals.get('process_file_bytes');
                const result = processFunc(uint8Array, file.name);
                
                const status = result.get(0);
                if (status === "ERROR") {
                    let errMsg = result.get(1);
                    console.error(errMsg);
                    statusText.setAttribute('data-status', 'fail');
                    statusText.innerText = texts.fail;
                    statusText.style.color = 'var(--error)';
                    statusIcon.innerHTML = `<span class="material-symbols-rounded status-icon error" title="Please check console for details">error</span>`;
                    return;
                }
                
                const filename = result.get(1);
                const outBytesProxy = result.get(2);
                let outBytes = outBytesProxy.toJs ? outBytesProxy.toJs() : outBytesProxy;
                
                const blob = new Blob([outBytes], { type: "application/octet-stream" });
                const url = URL.createObjectURL(blob);
                const a = document.createElement("a");
                a.href = url;
                a.download = filename;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
                
                statusText.setAttribute('data-status', 'success');
                statusText.innerText = texts.success;
                statusText.style.color = 'var(--success)';
                statusIcon.innerHTML = `<span class="material-symbols-rounded status-icon success">check_circle</span>`;
            } catch (err) {
                console.error(err);
                const errMsg = err.message || err;
                statusText.setAttribute('data-status', 'error:' + errMsg);
                statusText.innerText = (currentLang === 'zh' ? '错误: ' : 'Error: ') + errMsg;
                statusText.style.color = 'var(--error)';
                statusIcon.innerHTML = `<span class="material-symbols-rounded status-icon error">error</span>`;
            }
        }
    
</script>
